OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=your_llm_model_here
OPENROUTER_TEMPERATURE=0.1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_DEFAULT_SEARCH_DEPTH=advanced

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

MAX_SEARCH_RESULTS=5
MAX_QUERY_DECOMPOSITION_QUERIES=4
TOP_K_CHUNKS=8
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
MAX_ITERATIONS=2
MAX_EVIDENCE_RETRIES=2
REFLECTION_STEPS=1
CANDIDATE_POOL_SIZE=20
RERANK_TOP_K=8
FILTER_TOP_K=6

ENABLE_HYBRID_RETRIEVAL=true
ENABLE_CROSS_ENCODER_RERANKING=true
ENABLE_QUERY_DECOMPOSITION=true
ENABLE_ITERATIVE_RETRIEVAL=true
ENABLE_SELF_RAG=true
ENABLE_EVIDENCE_FILTERING=true
ENABLE_EVIDENCE_SUFFICIENCY=true
ENABLE_HYDE=true
ENABLE_PERFORMANCE_ANALYSIS=true
